# Tavily Search API (1,000 free credits/month — built for AI agents, get key at https://app.tavily.com/)
TAVILY_API_KEY=

# Testnet (required)
TESTNET_SERVER_STELLAR_ADDRESS=   # Your Stellar G... address to receive payments
TESTNET_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
TESTNET_FACILITATOR_API_KEY=      # Optional — leave blank for public facilitator

# Mainnet (optional)
MAINNET_SERVER_STELLAR_ADDRESS=
MAINNET_FACILITATOR_URL=https://channels.openzeppelin.com/x402/mainnet
MAINNET_STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
MAINNET_FACILITATOR_API_KEY=

# App config
PAYMENT_PRICE=0.01           # USDC per query
SEARCH_RESULTS_COUNT=10      # default results per query (max 20)
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
PAYWALL_DISABLED=false       # set true to disable payment for testing
