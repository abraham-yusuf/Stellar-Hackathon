# Your Stellar secret key (the agent's wallet that pays for searches)
# Generate a testnet keypair at https://laboratory.stellar.org/#account-creator?network=test
STELLAR_SECRET_KEY=S...

# Network: stellar:testnet or stellar:pubnet
STELLAR_NETWORK=stellar:testnet

# StellarSearch API server URL
SEARCH_API_URL=http://localhost:3001

# Optional: max payment per query in USDC (safety limit)
MAX_PAYMENT_USDC=0.10

# Optional: custom facilitator URL (defaults to Built on Stellar facilitator)
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_FACILITATOR_API_KEY=
